---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Development Board" noindex>
  <main class="dev-page" data-pagefind-ignore="all">
    <img class="dev-mark" src="/images/Group_935_Logo.webp" alt="" aria-hidden="true" />

    <section class="dev-hero" aria-labelledby="dev-title">
      <p class="dev-kicker">[ INTERNAL BUILD QUEUE ]</p>
      <div class="dev-title-row">
        <div>
          <h1 id="dev-title">DEVELOPMENT BOARD</h1>
          <p class="dev-subtitle">Track features, fixes, tweaks, and experiments before they enter the outbreak.</p>
        </div>
        <div class="dev-counters" aria-label="Board counters">
          <span><strong id="total-count">0</strong> total</span>
          <span><strong id="due-count">0</strong> due soon</span>
        </div>
      </div>
    </section>

    <section class="dev-composer" aria-labelledby="composer-title">
      <div class="composer-head">
        <div>
          <p class="dev-kicker">[ NEW CARD ]</p>
          <h2 id="composer-title">Create Work Item</h2>
        </div>
        <button class="quiet-btn is-hidden" id="cancel-edit" type="button">Cancel edit</button>
      </div>

      <form id="card-form" class="card-form">
        <input id="card-id" type="hidden" />

        <label class="form-field field-title">
          <span>Title</span>
          <input id="card-title" type="text" maxlength="80" placeholder="Add map route planner" required />
        </label>

        <label class="form-field">
          <span>Type</span>
          <select id="card-type" required>
            <option value="Feature">Feature</option>
            <option value="Bug Fix">Bug Fix</option>
            <option value="Tweak">Tweak</option>
            <option value="Content">Content</option>
            <option value="Design">Design</option>
            <option value="Research">Research</option>
            <option value="Performance">Performance</option>
            <option value="Chore">Chore</option>
          </select>
        </label>

        <label class="form-field">
          <span>Forecast date</span>
          <input id="card-due" type="date" required />
        </label>

        <label class="form-field">
          <span>Status</span>
          <select id="card-status" required>
            <option value="todo">To Do</option>
            <option value="progress">In Progress</option>
            <option value="done">Done</option>
          </select>
        </label>

        <label class="form-field field-description">
          <span>Description</span>
          <textarea id="card-description" rows="3" maxlength="420" placeholder="What needs to change, where, and why?" required></textarea>
        </label>

        <div class="form-actions">
          <button class="primary-btn" id="submit-card" type="submit">Create card</button>
          <button class="quiet-btn" id="clear-board" type="button">Clear done</button>
        </div>
      </form>
    </section>

    <section class="board-shell" aria-label="Development board">
      <article class="board-column" data-status="todo">
        <header class="column-head">
          <div>
            <p class="column-label">Backlog</p>
            <h2>To Do</h2>
          </div>
          <span class="column-count" data-count="todo">0</span>
        </header>
        <div class="column-drop" data-dropzone="todo"></div>
      </article>

      <article class="board-column" data-status="progress">
        <header class="column-head">
          <div>
            <p class="column-label">Active</p>
            <h2>In Progress</h2>
          </div>
          <span class="column-count" data-count="progress">0</span>
        </header>
        <div class="column-drop" data-dropzone="progress"></div>
      </article>

      <article class="board-column" data-status="done">
        <header class="column-head">
          <div>
            <p class="column-label">Shipped</p>
            <h2>Done</h2>
          </div>
          <span class="column-count" data-count="done">0</span>
        </header>
        <div class="column-drop" data-dropzone="done"></div>
      </article>
    </section>
  </main>
</Layout>

<script is:inline>
