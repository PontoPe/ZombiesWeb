    const form = document.getElementById('card-form');
    const idInput = document.getElementById('card-id');
    const titleInput = document.getElementById('card-title');
    const typeInput = document.getElementById('card-type');
    const dueInput = document.getElementById('card-due');
    const statusInput = document.getElementById('card-status');
    const descriptionInput = document.getElementById('card-description');
    const submitButton = document.getElementById('submit-card');
    const cancelEditButton = document.getElementById('cancel-edit');
    const clearDoneButton = document.getElementById('clear-board');
    const totalCount = document.getElementById('total-count');
    const dueCount = document.getElementById('due-count');

    if (!form || !idInput || !titleInput || !typeInput || !dueInput || !statusInput || !descriptionInput) return;

    let cards = loadCards();
    setDefaultDueDate();
    render();

    form.addEventListener('submit', function (event) {
      event.preventDefault();

      const cardId = getInputValue(idInput);
      const now = new Date().toISOString();
      const nextCard = {
        id: cardId || createId(),
        title: getInputValue(titleInput),
        type: getInputValue(typeInput),
        dueDate: getInputValue(dueInput),
        status: getInputValue(statusInput),
        description: getInputValue(descriptionInput),
        createdAt: now,
        updatedAt: now,
      };

      if (cardId) {
        cards = cards.map(function (card) {
          return card.id === cardId
            ? Object.assign({}, card, nextCard, { createdAt: card.createdAt || now, updatedAt: now })
            : card;
        });
      } else {
        cards = [nextCard].concat(cards);
      }

      saveCards();
      resetForm();
      render();
    });

    cancelEditButton?.addEventListener('click', resetForm);

    clearDoneButton?.addEventListener('click', function () {
      const doneCount = cards.filter(function (card) { return card.status === 'done'; }).length;
      if (!doneCount) return;
      const ok = window.confirm('Remove all Done cards?');
      if (!ok) return;
      cards = cards.filter(function (card) { return card.status !== 'done'; });
      saveCards();
      render();
    });

    document.querySelectorAll('[data-dropzone]').forEach(function (zone) {
      zone.addEventListener('dragover', function (event) {
        event.preventDefault();
        zone.classList.add('is-over');
      });

      zone.addEventListener('dragleave', function () {
        zone.classList.remove('is-over');
      });

      zone.addEventListener('drop', function (event) {
        event.preventDefault();
        zone.classList.remove('is-over');
        const status = zone.getAttribute('data-dropzone');
        const id = event.dataTransfer?.getData('text/plain');
        if (!status || !id) return;
        moveCard(id, status);
      });
    });

    document.addEventListener('click', function (event) {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const actionButton = target.closest('[data-action]');
      if (!(actionButton instanceof HTMLElement)) return;

      const id = actionButton.getAttribute('data-id');
      const action = actionButton.getAttribute('data-action');
      if (!id || !action) return;

      if (action === 'edit') editCard(id);
      if (action === 'delete') deleteCard(id);
      if (action === 'move-prev') moveCard(id, getAdjacentStatus(id, -1));
      if (action === 'move-next') moveCard(id, getAdjacentStatus(id, 1));
    });

    function loadCards() {
      try {
        const raw = window.localStorage.getItem(STORAGE_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        const savedCards = Array.isArray(parsed) ? parsed.filter(isValidCard) : [];
        const seedVersion = window.localStorage.getItem(SEED_KEY);
        if (seedVersion === SEED_VERSION) return savedCards;

        const mergedCards = mergeSeedCards(savedCards);
        window.localStorage.setItem(SEED_KEY, SEED_VERSION);
        window.localStorage.setItem(STORAGE_KEY, JSON.stringify(mergedCards));
        return mergedCards;
      } catch (error) {
        console.warn('Development board storage is unavailable.', error);
        return mergeSeedCards([]);
      }
    }

    function saveCards() {
      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(cards));
    }

    function mergeSeedCards(savedCards) {
      const existingIds = new Set(savedCards.map(function (card) { return card.id; }));
      const now = new Date().toISOString();
      const seedCards = SEEDED_TODO_CARDS
        .filter(function (seed) { return !existingIds.has(seed.id); })
        .map(function (seed) {
          return {
            id: seed.id,
            title: seed.title,
            type: seed.type,
            dueDate: toDateInputValue(addDays(seed.dueOffsetDays)),
            status: 'todo',
            description: seed.description,
            source: seed.source,
            createdAt: now,
            updatedAt: now,
          };
        });

      return savedCards.concat(seedCards);
    }

    function render() {
      STATUSES.forEach(function (status) {
        const zone = document.querySelector('[data-dropzone="' + status + '"]');
        if (!zone) return;

        const statusCards = cards
          .filter(function (card) { return card.status === status; })
          .sort(sortCards);

        zone.innerHTML = statusCards.length
          ? statusCards.map(renderCard).join('')
          : '<div class="empty-state">Drop cards here or create one above.</div>';
      });

      updateCounts();
      wireDragStarts();
    }

    function renderCard(card) {
      const dueState = getDueState(card.dueDate);
      const previousStatus = getAdjacentStatus(card.id, -1);
      const nextStatus = getAdjacentStatus(card.id, 1);

      return [
        '<article class="task-card" draggable="true" data-card-id="' + escapeHtml(card.id) + '">',
          '<div class="task-topline">',
            '<span class="type-pill type-' + slugify(card.type) + '">' + escapeHtml(card.type) + '</span>',
            '<span class="due-pill ' + dueState.className + '">' + escapeHtml(dueState.label) + '</span>',
          '</div>',
          '<h3>' + escapeHtml(card.title) + '</h3>',
          '<p class="task-description">' + escapeHtml(card.description) + '</p>',
          '<div class="task-meta">',
            '<span>Forecast</span>',
            '<strong>' + escapeHtml(formatDate(card.dueDate)) + '</strong>',
          '</div>',
          card.source ? '<div class="task-source">' + escapeHtml(card.source) + '</div>' : '',
          '<div class="task-actions">',
            '<button type="button" data-action="move-prev" data-id="' + escapeHtml(card.id) + '"' + (previousStatus ? '' : ' disabled') + '>Prev</button>',
            '<button type="button" data-action="move-next" data-id="' + escapeHtml(card.id) + '"' + (nextStatus ? '' : ' disabled') + '>Next</button>',
            '<button type="button" data-action="edit" data-id="' + escapeHtml(card.id) + '">Edit</button>',
            '<button type="button" data-action="delete" data-id="' + escapeHtml(card.id) + '">Delete</button>',
          '</div>',
        '</article>',
      ].join('');
    }

    function wireDragStarts() {
      document.querySelectorAll('[data-card-id]').forEach(function (cardEl) {
        cardEl.addEventListener('dragstart', function (event) {
          const id = cardEl.getAttribute('data-card-id') || '';
          event.dataTransfer?.setData('text/plain', id);
          event.dataTransfer?.setData('application/x-development-card', id);
          event.dataTransfer.effectAllowed = 'move';
          cardEl.classList.add('is-dragging');
        });

        cardEl.addEventListener('dragend', function () {
          cardEl.classList.remove('is-dragging');
          document.querySelectorAll('.column-drop.is-over').forEach(function (zone) {
            zone.classList.remove('is-over');
          });
        });
      });
    }

    function updateCounts() {
      STATUSES.forEach(function (status) {
        const countEl = document.querySelector('[data-count="' + status + '"]');
        const count = cards.filter(function (card) { return card.status === status; }).length;
        if (countEl) countEl.textContent = String(count);
      });

      if (totalCount) totalCount.textContent = String(cards.length);
      if (dueCount) {
        dueCount.textContent = String(cards.filter(function (card) {
          if (card.status === 'done') return false;
          const state = getDueState(card.dueDate);
          return state.key === 'overdue' || state.key === 'soon' || state.key === 'today';
        }).length);
      }
    }

    function editCard(id) {
      const card = cards.find(function (item) { return item.id === id; });
      if (!card) return;

      setInputValue(idInput, card.id);
      setInputValue(titleInput, card.title);
      setInputValue(typeInput, card.type);
      setInputValue(dueInput, card.dueDate);
      setInputValue(statusInput, card.status);
      setInputValue(descriptionInput, card.description);

      if (submitButton) submitButton.textContent = 'Save card';
      cancelEditButton?.classList.remove('is-hidden');
      titleInput.focus();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function deleteCard(id) {
      const card = cards.find(function (item) { return item.id === id; });
      if (!card) return;
      const ok = window.confirm('Delete "' + card.title + '"?');
      if (!ok) return;
      cards = cards.filter(function (item) { return item.id !== id; });
      saveCards();
      render();
    }

    function moveCard(id, status) {
      if (!status) return;
      cards = cards.map(function (card) {
        return card.id === id
          ? Object.assign({}, card, { status: status, updatedAt: new Date().toISOString() })
          : card;
      });
      saveCards();
      render();
    }

    function getAdjacentStatus(id, direction) {
      const card = cards.find(function (item) { return item.id === id; });
      if (!card) return '';
      const index = STATUSES.indexOf(card.status);
      const nextIndex = index + direction;
      return STATUSES[nextIndex] || '';
    }

    function resetForm() {
      form.reset();
      setInputValue(idInput, '');
      setDefaultDueDate();
      if (submitButton) submitButton.textContent = 'Create card';
      cancelEditButton?.classList.add('is-hidden');
    }

    function setDefaultDueDate() {
      const tomorrow = new Date();
      tomorrow.setDate(tomorrow.getDate() + 1);
      setInputValue(dueInput, toDateInputValue(tomorrow));
    }

    function sortCards(a, b) {
      if (a.status === 'done' && b.status === 'done') {
        return String(b.updatedAt || '').localeCompare(String(a.updatedAt || ''));
      }

      const byDate = String(a.dueDate || '').localeCompare(String(b.dueDate || ''));
      if (byDate !== 0) return byDate;
      return String(b.createdAt || '').localeCompare(String(a.createdAt || ''));
    }

    function getDueState(dateValue) {
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const due = parseLocalDate(dateValue);
      if (!due) return { key: 'neutral', label: 'No date', className: 'due-neutral' };

      const diff = Math.round((due.getTime() - today.getTime()) / 86400000);
      if (diff < 0) return { key: 'overdue', label: 'Overdue', className: 'due-hot' };
      if (diff === 0) return { key: 'today', label: 'Today', className: 'due-warm' };
      if (diff <= 3) return { key: 'soon', label: diff + 'd left', className: 'due-warm' };
      return { key: 'later', label: diff + 'd left', className: 'due-cool' };
    }

    function parseLocalDate(value) {
      if (!value) return null;
      const parts = value.split('-').map(Number);
      if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
      return new Date(parts[0], parts[1] - 1, parts[2]);
    }

    function formatDate(value) {
      const date = parseLocalDate(value);
      if (!date) return 'No date';
      return new Intl.DateTimeFormat('en', { month: 'short', day: '2-digit', year: 'numeric' }).format(date);
    }

    function toDateInputValue(date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return year + '-' + month + '-' + day;
    }

    function addDays(days) {
      const date = new Date();
      date.setHours(0, 0, 0, 0);
      date.setDate(date.getDate() + days);
      return date;
    }

    function isValidCard(card) {
      return card
        && typeof card.id === 'string'
        && typeof card.title === 'string'
        && typeof card.description === 'string'
        && typeof card.type === 'string'
        && typeof card.dueDate === 'string'
        && STATUSES.includes(card.status);
    }

    function getInputValue(input) {
      return input instanceof HTMLInputElement || input instanceof HTMLSelectElement || input instanceof HTMLTextAreaElement
        ? input.value.trim()
        : '';
    }

    function setInputValue(input, value) {
      if (input instanceof HTMLInputElement || input instanceof HTMLSelectElement || input instanceof HTMLTextAreaElement) {
        input.value = value;
      }
    }

    function createId() {
      if (window.crypto?.randomUUID) return window.crypto.randomUUID();
      return 'card-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2);
    }

    function slugify(value) {
      return String(value).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, function (char) {
        return {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        }[char];
      });
    }
  })();
</script>

