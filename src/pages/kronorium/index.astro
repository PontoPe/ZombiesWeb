---
import LoreLayout from '../../layouts/LoreLayout.astro';
import KronoriumPage from '../../components/kronorium/KronoriumPage.tsx';
---

<LoreLayout title="The Kronorium">
  <KronoriumPage client:only="react" />
</LoreLayout>

<style is:global>
  
  .lore-body > astro-island,
  .lore-body > astro-island > * {
    display: flex;
    flex-direction: column;
    flex: 1;
    height: 100%;
    min-height: 0;
  }

  
  .react-flow__controls-button {
    background: #17130d !important;
    border-color: #2e2416 !important;
    color: #7a6a50 !important;
    fill: #7a6a50 !important;
  }
  .react-flow__controls-button:hover {
    background: #1e1810 !important;
    color: #c9a24a !important;
    fill: #c9a24a !important;
  }
  .react-flow__controls-button svg {
    fill: inherit !important;
  }
  .react-flow__minimap {
    border-radius: 2px !important;
  }
  .react-flow__edge-path {
    stroke-dasharray: none;
  }
</style>
