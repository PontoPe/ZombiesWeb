---
import LoreLayout from '../../../layouts/LoreLayout.astro';
import { MAP_LORE, type MapLoreEntry } from '../../../data/mapLore';

export async function getStaticPaths() {
  return MAP_LORE.map((entry) => ({
    params: { slug: entry.nodeId },
    props:  { entry },
  }));
}

interface Props { entry: MapLoreEntry }
const { entry } = Astro.props;
---

<LoreLayout title={entry.title}>

  <article class="lore-article" data-pagefind-body>

    <header class="lore-article-head">
      <p class="eyebrow">[ KRONORIUM ENTRY ]</p>
      <h1 class="lore-title">{entry.title}</h1>

      <dl class="lore-meta">
        <div><dt>Setting</dt><dd>{entry.header.setting}</dd></div>
        <div><dt>Crew</dt><dd>{entry.header.crew.join(' · ')}</dd></div>
        <div><dt>Story Impact</dt><dd>{entry.header.storyImpact}</dd></div>
        <div><dt>Zombie Controller</dt><dd>{entry.header.zombieController}</dd></div>
      </dl>
    </header>

    <section class="lore-section">
      <h2>Prelude</h2>
      {entry.prelude.map((s) => (
        <div class="sub">
          <h3>{s.heading}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </section>

    <section class="lore-section">
      <h2>The Quest</h2>
      {entry.quest.map((s) => (
        <div class="sub">
          <h3>{s.heading}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </section>

    <section class="lore-section">
      <h2>Aftermath</h2>
      {entry.aftermath.map((s) => (
        <div class="sub">
          <h3>{s.heading}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </section>

    <nav class="lore-nav">
      <a href="/kronorium">← Return to the Timeline Graph</a>
    </nav>

  </article>

</LoreLayout>

<style>
  :global(.lore-body) {
    overflow-y: auto !important;
    display: block !important;
  }

  .lore-article {
    max-width: 820px;
    margin: 0 auto;
    padding: 56px 40px 100px;
    color: #d4c29a;
    font-family: 'EB Garamond', Garamond, serif;
  }

  .eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: #c9a24a;
    opacity: 0.7;
    margin: 0 0 10px 0;
    text-transform: uppercase;
  }

  .lore-title {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    letter-spacing: 0.03em;
    color: #e8d9b0;
    margin: 0 0 28px 0;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .lore-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px 32px;
    padding: 20px 0 24px;
    border-top: 1px solid #2e2416;
    border-bottom: 1px solid #2e2416;
    margin: 0 0 40px 0;
  }
  .lore-meta > div { display: flex; flex-direction: column; gap: 3px; }
  .lore-meta dt {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    color: #7a6a50;
    text-transform: uppercase;
  }
  .lore-meta dd {
    margin: 0;
    font-size: 15px;
    color: #c9a24a;
    line-height: 1.45;
  }

  .lore-section { margin-bottom: 40px; }
  .lore-section h2 {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.12em;
    color: #c9a24a;
    text-transform: uppercase;
    margin: 0 0 16px 0;
    padding-bottom: 8px;
    border-bottom: 1px solid #2e2416;
  }

  .sub { margin-bottom: 22px; }
  .sub h3 {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    color: #e8d9b0;
    margin: 0 0 8px 0;
  }
  .sub p {
    font-size: 17px;
    line-height: 1.7;
    color: #c9b58a;
    margin: 0;
  }

  .lore-nav {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid #2e2416;
  }
  .lore-nav a {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #7a6a50;
    text-decoration: none;
    text-transform: uppercase;
  }
  .lore-nav a:hover { color: #c9a24a; }

  /* Make the body containing this article data-indexable */
  .lore-article { }
</style>
