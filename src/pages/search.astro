---
import OpsLayout from '../layouts/OpsLayout.astro';
---

<OpsLayout title="Search">

  <div class="search-shell" id="pf-shell">

    

  <div class="search-root" data-pagefind-ignore="all">

    <div class="search-network" id="pf-network">
      <div class="search-canvas" id="pf-canvas">
        <svg id="pf-links" class="search-links" aria-hidden="true"></svg>
        <div id="pf-results" class="search-results"></div>
        <div class="search-center">
          <div class="search-input-wrap">
            <span class="search-icon" aria-hidden="true">⌕</span>
            <input
              id="pf-input"
              type="search"
              class="search-input"
              placeholder='Try "Gorod Krovi", "teleporter", "Primis", "Juggernog"...'
              autocomplete="off"
              autofocus
            />
            <span class="search-hint">ENTER to search · ESC to clear</span>
          </div>
          <div id="pf-status" class="search-status"></div>
        </div>
      </div>
      <div class="search-pan-hint" aria-hidden="true">◇ DRAG TO PAN · SCROLL TO ZOOM</div>
      <div class="search-zoom-controls" aria-label="Zoom controls">
        <button type="button" class="zoom-btn" data-zoom="in" aria-label="Zoom in">+</button>
        <button type="button" class="zoom-btn" data-zoom="reset" aria-label="Reset view">◎</button>
        <button type="button" class="zoom-btn" data-zoom="out" aria-label="Zoom out">−</button>
      </div>
    </div>

  </div>

  </div>

</OpsLayout>

<script is:inline>
  (function () {
    document.body.classList.add('search-page');
    const from = new URLSearchParams(window.location.search).get('from');
    const back = document.querySelector('.nav-back');

    if (from === 'maps' && back instanceof HTMLAnchorElement) {
      back.setAttribute('href', '/maps');
      const spans = back.querySelectorAll('span');
      if (spans.length >= 2) spans[spans.length - 1].textContent = 'MAPS';
      return;
    }

    if (from !== 'kronorium') return;
    document.body.classList.add('search-lore-theme');
    const shell = document.getElementById('pf-shell');
    if (shell) shell.classList.add('lore-theme');
    if (back instanceof HTMLAnchorElement) {
      back.setAttribute('href', '/kronorium');
      const spans = back.querySelectorAll('span');
      if (spans.length >= 2) spans[spans.length - 1].textContent = 'KRONORIUM';
    }
  })();
</script>

<script is:inline>
  (function () {
    let pagefind = null;
    const params = new URLSearchParams(window.location.search);
    const isIntroMode = params.get('intro') === '1';
    const isLoreMode = params.get('from') === 'kronorium';

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.options({ excerptLength: 22 });
        return pagefind;
      } catch (err) {
        console.error('Pagefind load failed', err);
        return null;
      }
    }

    const input   = document.getElementById('pf-input');
    const results = document.getElementById('pf-results');
    const status  = document.getElementById('pf-status');
    const linksSvg = document.getElementById('pf-links');
    if (!input || !results || !status) return;
    const root = document.querySelector('.search-root');
    const inputWrap = document.querySelector('.search-input-wrap');
    if (isIntroMode && root instanceof HTMLElement) {
      root.classList.add('is-intro');
      document.body.classList.add('search-intro');
    }

    let debounce;

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function stripHtml(str) {
      return String(str).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
    }

    function buildHitUrl(rawUrl, excerpt) {
      const text = stripHtml(excerpt).slice(0, 120);
      if (!text) return rawUrl;

      const split = rawUrl.split('#');
      const base = split[0];
      const hash = split[1] || '';
      const anchor = hash ? hash.split(':~:text=')[0] : '';
      const fragment = '#'
        + (anchor ? anchor + ':~:text=' : ':~:text=')
        + encodeURIComponent(text);
      return base + fragment;
    }

    function getHitSource(rawUrl) {
      const path = String(rawUrl).split('#')[0].replace(/\/$/, '');

      if (path === '/maps' || path.indexOf('/maps/') === 0) {
        return { kind: 'maps', label: 'MAP FILE', context: 'FIELD MANUAL' };
      }

      if (path === '/kronorium' || path.indexOf('/kronorium/') === 0) {
        if (path.indexOf('/kronorium/lab') === 0) {
          return { kind: 'kronorium', label: 'LAB ARCHIVE', context: 'RICHTOFEN DOSSIER' };
        }

        return { kind: 'kronorium', label: 'KRONORIUM', context: 'LORE ENTRY' };
      }

      if (path === '/wonder-weapons' || path.indexOf('/wonder-weapons/') === 0) {
        return { kind: 'weapons', label: 'ARSENAL', context: 'WEAPON INDEX' };
      }

      return { kind: 'manual', label: 'FIELD MANUAL', context: 'REFERENCE' };
    }

    function shouldUseNodeLayout() {
      return true;
    }

    const network = document.getElementById('pf-network');
    const canvas = document.getElementById('pf-canvas');
    const CANVAS_W = 8000;
    const CANVAS_H = 6000;
    const CENTER_X = CANVAS_W / 2;
    const CENTER_Y = CANVAS_H / 2;
    const MIN_SCALE = 0.25;
    const MAX_SCALE = 1.6;
    let panX = 0;
    let panY = 0;
    const DEFAULT_SCALE = isLoreMode ? 1 : 1.1;
    let scale = DEFAULT_SCALE;

    function applyPan() {
      if (canvas instanceof HTMLElement) {
        canvas.style.transform = 'translate(' + panX + 'px, ' + panY + 'px) scale(' + scale + ')';
      }
    }

    function resetPan() {
      scale = DEFAULT_SCALE;
      if (!(network instanceof HTMLElement)) { panX = 0; panY = 0; applyPan(); return; }
      const netRect = network.getBoundingClientRect();
      const targetY = isLoreMode
        ? Math.max(0, (window.innerHeight / 2) - netRect.top)
        : netRect.height / 2;
      panX = (netRect.width / 2) - (CENTER_X * scale);
      panY = targetY - (CENTER_Y * scale);
      applyPan();
    }

    function zoomAt(newScale, focalClientX, focalClientY) {
      if (!(network instanceof HTMLElement)) return;
      newScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, newScale));
      const netRect = network.getBoundingClientRect();
      const fx = (focalClientX != null ? focalClientX : netRect.left + netRect.width / 2) - netRect.left;
      const fy = (focalClientY != null ? focalClientY : netRect.top + netRect.height / 2) - netRect.top;
      const cx = (fx - panX) / scale;
      const cy = (fy - panY) / scale;
      scale = newScale;
      panX = fx - cx * scale;
      panY = fy - cy * scale;
      applyPan();
    }

    function positionNodes() {
      if (!(root instanceof HTMLElement) || !(linksSvg instanceof SVGSVGElement) || !(network instanceof HTMLElement)) return;
      if (!root.classList.contains('has-query') || !root.classList.contains('node-layout')) {
        linksSvg.innerHTML = '';
        return;
      }

      const nodeEls = Array.from(results.querySelectorAll('.hit'));
      if (!nodeEls.length) {
        linksSvg.innerHTML = '';
        return;
      }

      linksSvg.setAttribute('viewBox', '0 0 ' + CANVAS_W + ' ' + CANVAS_H);
      linksSvg.setAttribute('width', String(CANVAS_W));
      linksSvg.setAttribute('height', String(CANVAS_H));

      const centerX = CENTER_X;
      const centerY = CENTER_Y;

      const nodeWidth = 280;
      const nodeHeight = 140;
      const perRing = 7;
      const minRadiusX = 870;
      const minRadiusY = 435;
      const ringStep = 400;

      const positions = [];
      nodeEls.forEach(function (node, i) {
        const ring = Math.floor(i / perRing);
        const idxInRing = i % perRing;
        const countInRing = Math.min(perRing, nodeEls.length - ring * perRing);
        const ringOffset = ring * 0.42;
        const angle = (-Math.PI / 2) + ringOffset + (idxInRing * ((Math.PI * 2) / countInRing));
        const rx = minRadiusX + (ring * ringStep);
        const ry = minRadiusY + (ring * ringStep * 0.82);
        const cx = centerX + Math.cos(angle) * rx;
        const cy = centerY + Math.sin(angle) * ry;
        const x = cx - (nodeWidth / 2);
        const y = cy - (nodeHeight / 2);
        node.style.left = x + 'px';
        node.style.top = y + 'px';
        positions.push({ x: cx, y: cy });
      });

      linksSvg.innerHTML = positions.map(function (p) {
        return '<line x1="' + centerX.toFixed(1) + '" y1="' + centerY.toFixed(1) + '" x2="' + p.x.toFixed(1) + '" y2="' + p.y.toFixed(1) + '" stroke="currentColor" stroke-width="1.4" stroke-dasharray="6 6" vector-effect="non-scaling-stroke" />';
      }).join('');
    }

    (function initPan() {
      if (!(network instanceof HTMLElement)) return;
      let dragging = false;
      let startX = 0;
      let startY = 0;
      let startPanX = 0;
      let startPanY = 0;
      let pointerId = null;

      network.addEventListener('pointerdown', function (e) {
        if (!(e.target instanceof Element)) return;
        if (e.target.closest('.hit')) return;
        if (e.target.closest('.search-center')) return;
        if (!root || !root.classList.contains('node-layout')) return;
        dragging = true;
        pointerId = e.pointerId;
        startX = e.clientX;
        startY = e.clientY;
        startPanX = panX;
        startPanY = panY;
        network.classList.add('is-panning');
        try { network.setPointerCapture(e.pointerId); } catch (_) {}
      });

      network.addEventListener('pointermove', function (e) {
        if (!dragging || e.pointerId !== pointerId) return;
        panX = startPanX + (e.clientX - startX);
        panY = startPanY + (e.clientY - startY);
        applyPan();
      });

      function endDrag(e) {
        if (!dragging) return;
        dragging = false;
        network.classList.remove('is-panning');
        try { network.releasePointerCapture(e.pointerId); } catch (_) {}
      }
      network.addEventListener('pointerup', endDrag);
      network.addEventListener('pointercancel', endDrag);

      network.addEventListener('wheel', function (e) {
        if (!root || !root.classList.contains('node-layout')) return;
        e.preventDefault();
        const delta = -e.deltaY;
        const factor = Math.exp(delta * 0.0015);
        zoomAt(scale * factor, e.clientX, e.clientY);
      }, { passive: false });

      const zoomBtns = document.querySelectorAll('.zoom-btn');
      zoomBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const kind = btn.getAttribute('data-zoom');
          if (kind === 'in') zoomAt(scale * 1.25);
          else if (kind === 'out') zoomAt(scale / 1.25);
          else resetPan();
        });
      });
    })();

    async function runSearch(q) {
      if (root instanceof HTMLElement) {
        root.classList.toggle('has-query', !!q.trim());
        root.classList.toggle('node-layout', shouldUseNodeLayout());
      }
      document.body.classList.toggle('search-has-query', !!q.trim());
      if (!q.trim()) {
        results.innerHTML = '';
        status.textContent = '';
        positionNodes();
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        status.textContent = 'SEARCH INDEX UNAVAILABLE — run `npm run build` and then `npm run preview` (or copy `dist/pagefind` into `public/pagefind` for dev).';
        return;
      }
      status.textContent = 'SEARCHING...';
      const search = await pf.search(q);
      const hits = await Promise.all(search.results.map(function (r) { return r.data(); }));

      if (hits.length === 0) {
        status.textContent = 'NO RESULTS FOR "' + q + '"';
        results.innerHTML = '';
        positionNodes();
        return;
      }

      status.textContent = search.results.length + ' RESULT' + (search.results.length === 1 ? '' : 'S');
      results.innerHTML = hits.map(function (h) {
        const title = escapeHtml((h.meta && h.meta.title) || h.url);
        const url   = escapeHtml(h.url);
        const hitUrl = escapeHtml(buildHitUrl(h.url, h.excerpt));
        const source = getHitSource(h.url);
        return '<a class="hit hit--' + source.kind + '" href="' + hitUrl + '" tabindex="0">' +
          '<span class="hit-ribbon" aria-hidden="true"></span>' +
          '<div class="hit-meta-row">' +
            '<span class="hit-source">' + source.label + '</span>' +
            '<span class="hit-context">' + source.context + '</span>' +
          '</div>' +
          '<div class="hit-head">' +
            '<span class="hit-title">' + title + '</span>' +
            '<span class="hit-action">OPEN</span>' +
          '</div>' +
          '<div class="hit-url">' + url + '</div>' +
          '<p class="hit-excerpt">' + h.excerpt + '</p>' +
        '</a>';
      }).join('');
      window.requestAnimationFrame(positionNodes);
    }

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        runSearch(input.value);
      } else if (e.key === 'Escape') {
        input.value = '';
        runSearch('');
      }
    });

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(function () { loadPagefind(); });
    }

    window.addEventListener('resize', function () {
      if (root instanceof HTMLElement) {
        root.classList.toggle('node-layout', root.classList.contains('has-query') && shouldUseNodeLayout());
      }
      if (root instanceof HTMLElement && !root.classList.contains('has-query')) {
        window.requestAnimationFrame(resetPan);
      }
      window.requestAnimationFrame(positionNodes);
    });

    if (root instanceof HTMLElement) {
      root.classList.toggle('node-layout', shouldUseNodeLayout());
    }
    resetPan();
    window.requestAnimationFrame(resetPan);
    window.addEventListener('load', resetPan, { once: true });

    const q0 = params.get('q');
    if (q0) { input.value = q0; runSearch(q0); }
  })();
</script>

<style>
  .page-header {
    position: relative;
    margin: 0 auto 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid #1e2028;
    text-align: center;
    max-width: 720px;
    transition: opacity 0.2s ease, transform 0.2s ease, height 0.2s ease;
  }
  :global(body.search-has-query) .page-header {
    display: none;
  }
  .header-hud-tl {
    position: absolute; top: 0; left: 0;
    width: 24px; height: 24px;
    border-top: 2px solid #e07b2a;
    border-left: 2px solid #e07b2a;
    opacity: 0.6;
  }
  .header-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px; letter-spacing: 0.28em;
    color: #e07b2a; opacity: 0.8;
    margin: 0 0 10px 0;
  }
  .header-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1; color: #dde1ea;
    letter-spacing: 0.04em; text-transform: uppercase;
    margin: 0 0 12px 0;
  }
  .header-sub {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px; color: #4a4e5a;
    letter-spacing: 0.1em; margin: 0;
  }
  .header-count { color: #e07b2a; }

  .search-root {
    position: relative;
    max-width: none;
    min-height: calc(100vh - 180px);
    transition: transform 0.36s ease, opacity 0.24s ease;
  }

  .search-center {
    position: absolute;
    left: 4000px;
    top: 3000px;
    transform: translate(-50%, -50%);
    width: 720px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: stretch;
    pointer-events: auto;
    z-index: 2;
  }

  .search-input-wrap {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    border: 1px solid #252830;
    background: rgba(15, 17, 20, 0.94);
    padding: 0 16px;
    transition: border-color 0.15s;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(224, 123, 42, 0.08);
  }
  .search-input-wrap:focus-within { border-color: #e07b2a; }

  .search-icon {
    font-size: 20px;
    color: #e07b2a;
    margin-right: 12px;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    padding: 18px 0;
    color: #dde1ea;
    font-family: 'Rajdhani', sans-serif;
    font-size: 18px;
    letter-spacing: 0.02em;
  }
  .search-input::placeholder { color: #4a4e5a; }

  .search-hint {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    color: #4a4e5a;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .search-status {
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #e07b2a;
    opacity: 0.8;
    min-height: 14px;
    text-transform: uppercase;
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  :global(body.search-intro) .page-header {
    opacity: 0;
    transform: translateY(-14px);
    pointer-events: none;
    height: 0;
    margin: 0;
    padding: 0;
    border: 0;
    overflow: hidden;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .search-root .search-status,
  .search-root .search-results {
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  .search-root:not(.has-query) .search-status,
  .search-root:not(.has-query) .search-results {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  .search-root.has-query .search-status,
  .search-root.has-query .search-results {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .search-network {
    position: fixed;
    top: 52px;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #0b0c0f;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .search-root { z-index: 2; }
  .search-input-wrap { z-index: 3; }

  .search-root.node-layout .search-network {
    pointer-events: auto;
    cursor: grab;
  }
  .search-root.node-layout .search-network.is-panning {
    cursor: grabbing;
  }

  .search-canvas {
    position: absolute;
    left: 0;
    top: 0;
    width: 8000px;
    height: 6000px;
    background-image:
      linear-gradient(rgba(224, 123, 42, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(224, 123, 42, 0.04) 1px, transparent 1px);
    background-size: 44px 44px;
    transform-origin: 0 0;
    transform: translate(calc(50vw - 4400px), calc((100vh - 52px) / 2 - 3300px)) scale(1.1);
    will-change: transform;
  }

  .search-pan-hint {
    position: absolute;
    right: 16px;
    bottom: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: #4a4e5a;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .search-root.node-layout .search-pan-hint { opacity: 0.7; }

  .search-zoom-controls {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 4;
    pointer-events: auto;
  }
  .zoom-btn {
    width: 36px;
    height: 36px;
    border: 1px solid #2a2e38;
    background: rgba(15, 17, 20, 0.92);
    color: #c4c8d4;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    padding: 0;
  }
  .zoom-btn:hover {
    border-color: #e07b2a;
    color: #e07b2a;
    background: rgba(15, 17, 20, 1);
  }

  .search-links {
    position: absolute;
    left: 0;
    top: 0;
    width: 8000px;
    height: 6000px;
    pointer-events: none;
    z-index: 0;
    color: rgba(224, 123, 42, 0.5);
  }
  .search-shell.lore-theme .search-links {
    color: rgba(201, 162, 74, 0.6);
  }
  .search-links line {
    stroke: rgba(224, 123, 42, 0.32);
    stroke-width: 1.1;
    stroke-dasharray: 4 5;
  }

  .search-root.node-layout.has-query .search-results {
    position: absolute;
    left: 0;
    top: 0;
    width: 8000px;
    height: 6000px;
    display: block;
    z-index: 1;
    pointer-events: none;
  }

  .search-root.node-layout.has-query :global(.hit) {
    pointer-events: auto;
  }

  .search-root:not(.node-layout).has-query .search-network {
    position: static;
    pointer-events: auto;
    margin-top: 24px;
  }
  .search-root:not(.node-layout).has-query .search-links { display: none; }
  .search-root:not(.node-layout).has-query .search-results {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .search-root.node-layout.has-query :global(.hit) {
    position: absolute;
    width: 280px;
    min-height: 126px;
    padding: 14px 16px 14px 20px;
    backdrop-filter: blur(2px);
    box-shadow: 0 0 0 1px rgba(224, 123, 42, 0.08);
  }

  .search-root.node-layout.has-query :global(.hit .hit-url) {
    max-width: 100%;
  }

  :global(.hit) {
    --hit-accent: #e07b2a;
    --hit-accent-soft: rgba(224, 123, 42, 0.14);
    --hit-surface: rgba(15, 17, 20, 0.94);
    position: relative;
    display: grid;
    gap: 9px;
    overflow: hidden;
    border: 1px solid #292d37;
    border-left-color: var(--hit-accent);
    background:
      linear-gradient(90deg, var(--hit-accent-soft), transparent 34%),
      var(--hit-surface);
    padding: 15px 18px 16px 22px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
  }
  :global(.hit:hover),
  :global(.hit:focus-visible) {
    border-color: var(--hit-accent);
    transform: translateY(-1px);
    outline: none;
  }
  :global(.hit--maps) {
    --hit-accent: #3ddc84;
    --hit-accent-soft: rgba(61, 220, 132, 0.14);
    --hit-surface: rgba(10, 18, 17, 0.94);
  }
  :global(.hit--kronorium) {
    --hit-accent: #c9a24a;
    --hit-accent-soft: rgba(201, 162, 74, 0.16);
    --hit-surface: rgba(21, 16, 11, 0.95);
  }
  :global(.hit--weapons) {
    --hit-accent: #d1463f;
