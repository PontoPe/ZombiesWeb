---
import OpsLayout from '../layouts/OpsLayout.astro';
---

<OpsLayout title="Search">

  <header class="page-header">
    <div class="header-hud-tl" aria-hidden="true"></div>
    <p class="header-eyebrow">[ OPERATIVE DATABASE · INDEX ]</p>
    <h1 class="header-title">SEARCH</h1>
    <p class="header-sub">
      <span class="header-count">FULL-TEXT</span>
      &nbsp;·&nbsp; Maps, lore, wonder weapons, perks, FAQs
    </p>
  </header>

  <div class="search-root" data-pagefind-ignore="all">

    <div class="search-input-wrap">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input
        id="pf-input"
        type="search"
        class="search-input"
        placeholder='Try "Gorod Krovi", "teleporter", "Primis", "Juggernog"...'
        autocomplete="off"
        autofocus
      />
      <span class="search-hint">ESC to clear</span>
    </div>

    <div id="pf-status" class="search-status"></div>
    <div class="search-network">
      <svg id="pf-links" class="search-links" aria-hidden="true"></svg>
      <div id="pf-results" class="search-results"></div>
    </div>

  </div>

</OpsLayout>

<script is:inline>
  (function () {
    let pagefind = null;
    const isIntroMode = new URLSearchParams(window.location.search).get('intro') === '1';

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.options({ excerptLength: 22 });
        return pagefind;
      } catch (err) {
        console.error('Pagefind load failed', err);
        return null;
      }
    }

    const input   = document.getElementById('pf-input');
    const results = document.getElementById('pf-results');
    const status  = document.getElementById('pf-status');
    const linksSvg = document.getElementById('pf-links');
    if (!input || !results || !status) return;
    const root = document.querySelector('.search-root');
    const inputWrap = document.querySelector('.search-input-wrap');
    if (isIntroMode && root instanceof HTMLElement) {
      root.classList.add('is-intro');
      document.body.classList.add('search-intro');
    }

    let debounce;

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function stripHtml(str) {
      return String(str).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
    }

    function buildHitUrl(rawUrl, excerpt) {
      const text = stripHtml(excerpt).slice(0, 120);
      if (!text) return rawUrl;

      const split = rawUrl.split('#');
      const base = split[0];
      const hash = split[1] || '';
      const anchor = hash ? hash.split(':~:text=')[0] : '';
      const fragment = '#'
        + (anchor ? anchor + ':~:text=' : ':~:text=')
        + encodeURIComponent(text);
      return base + fragment;
    }

    function positionNodes() {
      if (!(root instanceof HTMLElement) || !(inputWrap instanceof HTMLElement) || !(linksSvg instanceof SVGSVGElement)) return;
      if (!root.classList.contains('is-intro') || !root.classList.contains('has-query') || window.innerWidth < 900) {
        linksSvg.innerHTML = '';
        return;
      }

      const nodeEls = Array.from(results.querySelectorAll('.hit'));
      if (!nodeEls.length) {
        linksSvg.innerHTML = '';
        return;
      }

      const network = results.parentElement;
      if (!(network instanceof HTMLElement)) return;
      const netRect = network.getBoundingClientRect();
      const wrapRect = inputWrap.getBoundingClientRect();
      const width = Math.max(1, Math.floor(netRect.width));
      const height = Math.max(1, Math.floor(netRect.height));

      linksSvg.setAttribute('viewBox', '0 0 ' + width + ' ' + height);
      linksSvg.setAttribute('width', String(width));
      linksSvg.setAttribute('height', String(height));

      const centerX = wrapRect.left - netRect.left + (wrapRect.width / 2);
      const centerY = wrapRect.bottom - netRect.top + 10;
      const baseRadius = Math.min(width, height) * 0.36;

      const positions = [];
      nodeEls.forEach(function (node, i) {
        const angle = (-Math.PI / 2) + (i * ((Math.PI * 2) / nodeEls.length));
        const radiusOffset = ((i % 3) - 1) * 55;
        const radius = baseRadius + radiusOffset;
        const nodeWidth = 240;
        const nodeHeight = 110;
        const x = Math.min(width - nodeWidth, Math.max(0, centerX + (Math.cos(angle) * radius) - (nodeWidth / 2)));
        const y = Math.min(height - nodeHeight, Math.max(0, centerY + (Math.sin(angle) * radius) - (nodeHeight / 2)));
        node.style.left = x + 'px';
        node.style.top = y + 'px';
        positions.push({ x: x + (nodeWidth / 2), y: y + (nodeHeight / 2) });
      });

      linksSvg.innerHTML = positions.map(function (p) {
        return '<line x1="' + centerX.toFixed(1) + '" y1="' + centerY.toFixed(1) + '" x2="' + p.x.toFixed(1) + '" y2="' + p.y.toFixed(1) + '" />';
      }).join('');
    }

    async function runSearch(q) {
      if (root instanceof HTMLElement) {
        root.classList.toggle('has-query', !!q.trim());
      }
      if (!q.trim()) {
        results.innerHTML = '';
        status.textContent = '';
        positionNodes();
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        status.textContent = 'SEARCH INDEX UNAVAILABLE — run `npm run build` to generate /pagefind/';
        return;
      }
      status.textContent = 'SEARCHING...';
      const search = await pf.search(q);
      const hits = await Promise.all(search.results.slice(0, 30).map(function (r) { return r.data(); }));

      if (hits.length === 0) {
        status.textContent = 'NO RESULTS FOR "' + q + '"';
        results.innerHTML = '';
        positionNodes();
        return;
      }

      status.textContent = search.results.length + ' RESULT' + (search.results.length === 1 ? '' : 'S');
      results.innerHTML = hits.slice(0, root instanceof HTMLElement && root.classList.contains('is-intro') ? 14 : hits.length).map(function (h) {
        const title = escapeHtml((h.meta && h.meta.title) || h.url);
        const url   = escapeHtml(h.url);
        const hitUrl = escapeHtml(buildHitUrl(h.url, h.excerpt));
        return '<a class="hit" href="' + hitUrl + '" tabindex="0">' +
          '<div class="hit-head">' +
            '<span class="hit-title">' + title + '</span>' +
            '<span class="hit-url">' + url + '</span>' +
          '</div>' +
          '<p class="hit-excerpt">' + h.excerpt + '</p>' +
        '</a>';
      }).join('');
      window.requestAnimationFrame(positionNodes);
    }

    input.addEventListener('input', function () {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(function () { runSearch(input.value); }, 120);
    });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { input.value = ''; runSearch(''); }
    });

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(function () { loadPagefind(); });
    }

    window.addEventListener('resize', function () {
      window.requestAnimationFrame(positionNodes);
    });

    const params = new URLSearchParams(window.location.search);
    const q0 = params.get('q');
    if (q0) { input.value = q0; runSearch(q0); }
  })();
</script>

<style>
  .page-header {
    position: relative;
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid #1e2028;
  }
  .header-hud-tl {
    position: absolute; top: 0; left: 0;
    width: 24px; height: 24px;
    border-top: 2px solid #e07b2a;
    border-left: 2px solid #e07b2a;
    opacity: 0.6;
  }
  .header-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px; letter-spacing: 0.28em;
    color: #e07b2a; opacity: 0.8;
    margin: 0 0 10px 0; padding-left: 4px;
  }
  .header-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1; color: #dde1ea;
    letter-spacing: 0.04em; text-transform: uppercase;
    margin: 0 0 12px 0;
  }
  .header-sub {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px; color: #4a4e5a;
    letter-spacing: 0.1em; margin: 0;
  }
  .header-count { color: #e07b2a; }

  .search-root {
    max-width: 860px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.36s ease, opacity 0.24s ease;
  }

  .search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    border: 1px solid #252830;
    background: #0f1114;
    padding: 0 16px;
    transition: border-color 0.15s;
  }
  .search-input-wrap:focus-within { border-color: #e07b2a; }

  .search-icon {
    font-size: 20px;
    color: #e07b2a;
    margin-right: 12px;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    padding: 18px 0;
    color: #dde1ea;
    font-family: 'Rajdhani', sans-serif;
    font-size: 18px;
    letter-spacing: 0.02em;
  }
  .search-input::placeholder { color: #4a4e5a; }

  .search-hint {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    color: #4a4e5a;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .search-status {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #e07b2a;
    opacity: 0.8;
    min-height: 14px;
    text-transform: uppercase;
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  :global(body.search-intro) .page-header {
    opacity: 0;
    transform: translateY(-14px);
    pointer-events: none;
    height: 0;
    margin: 0;
    padding: 0;
    border: 0;
    overflow: hidden;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .search-root.is-intro {
    min-height: calc(100vh - 180px);
    justify-content: center;
  }

  .search-root.is-intro .search-status,
  .search-root.is-intro .search-results {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  .search-root.is-intro.has-query {
    justify-content: flex-start;
    min-height: auto;
  }

  .search-root.is-intro.has-query .search-status,
  .search-root.is-intro.has-query .search-results {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .search-network {
    position: relative;
    min-height: 0;
  }

  .search-links {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .search-links line {
    stroke: rgba(224, 123, 42, 0.32);
    stroke-width: 1.1;
    stroke-dasharray: 4 5;
  }

  .search-root.is-intro.has-query .search-network {
    min-height: 68vh;
  }

  .search-root.is-intro.has-query .search-results {
    position: relative;
    display: block;
    min-height: 68vh;
    z-index: 1;
  }

  .search-root.is-intro.has-query .hit {
    position: absolute;
    width: 240px;
    min-height: 110px;
    padding: 12px 14px;
    background: rgba(15, 17, 20, 0.92);
    backdrop-filter: blur(2px);
    box-shadow: 0 0 0 1px rgba(224, 123, 42, 0.08);
  }

  .search-root.is-intro.has-query .hit .hit-url {
    max-width: 92px;
  }

  .hit {
    display: block;
    border: 1px solid #1e2028;
    background: #0f1114;
    padding: 16px 20px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .hit:hover { border-color: #e07b2a; transform: translateY(-1px); }

  .hit-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 8px;
  }
  .hit-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.04em;
    color: #dde1ea;
    text-transform: uppercase;
  }
  .hit-url {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: #4a4e5a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hit-excerpt {
    font-family: 'Rajdhani', sans-serif;
    font-size: 14px;
    line-height: 1.55;
    color: #8a8f9e;
    margin: 0;
  }
  .hit-excerpt :global(mark) {
    background: rgba(224, 123, 42, 0.2);
    color: #e07b2a;
    padding: 0 2px;
  }

  @media (max-width: 640px) {
    .hit-head { flex-direction: column; gap: 2px; }
    .search-hint { display: none; }
  }

  @media (max-width: 900px) {
    .search-root.is-intro.has-query .search-network,
    .search-root.is-intro.has-query .search-results {
      min-height: auto;
    }

    .search-links {
      display: none;
    }

    .search-root.is-intro.has-query .hit {
      position: static;
      width: auto;
      min-height: 0;
      margin-bottom: 10px;
    }
  }
</style>
