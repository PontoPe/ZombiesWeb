---
interface Props {
  title?: string;
}
const { title = 'The Kronorium' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Caveat:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} — The Kronorium</title>
  </head>
  <body>

    <header class="lore-header">
      <a href="/" class="back-link">
        <span class="back-arrow">←</span>
        <span>FIELD MANUAL</span>
      </a>

      <div class="header-center">
        <span class="header-omega">Ω</span>
        <span class="header-title">{title === "Richtofen's Lab" ? "RICHTOFEN'S LAB" : 'THE KRONORIUM'}</span>
        <span class="header-omega">Ω</span>
      </div>

      <div class="header-right">
        <a href="/search" class="lore-search" aria-label="Search">
          <span class="lore-search-icon" aria-hidden="true">⌕</span>
          <span class="lore-search-label">SEARCH</span>
          <span class="lore-search-key">/</span>
        </a>
        <div class="header-file">FILE NO. Ω-532-115</div>
      </div>
    </header>

    <div class="lore-body">
      <slot />
    </div>

    <script>
      (function () {
        function goToSearchWithAnimation(triggerEl) {
          const body = document.body;
          if (!body || body.classList.contains('search-transitioning')) {
            window.location.href = '/search?intro=1';
            return;
          }

          body.classList.add('search-transitioning');

          const overlay = document.createElement('div');
          overlay.className = 'search-transition-overlay';

          const ghost = triggerEl.cloneNode(true);
          ghost.classList.add('search-transition-ghost');

          overlay.appendChild(ghost);
          body.appendChild(overlay);

          window.setTimeout(function () {
            overlay.classList.add('active');
          }, 10);

          window.setTimeout(function () {
            window.location.href = '/search?intro=1';
          }, 440);
        }

        const searchLink = document.querySelector('.lore-search');
        if (searchLink instanceof HTMLAnchorElement) {
          searchLink.addEventListener('click', function (e) {
            e.preventDefault();
            goToSearchWithAnimation(searchLink);
          });
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === '/' && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement)) {
            e.preventDefault();
            const trigger = searchLink instanceof HTMLAnchorElement ? searchLink : document.body;
            goToSearchWithAnimation(trigger);
          }
        });
      })();
    </script>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: #0e0b07;
    overflow: hidden;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  
  .lore-header {
    flex-shrink: 0;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    background: #110e09;
    border-bottom: 1px solid #2e2416;
    position: relative;
    z-index: 10;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: #5a4a32;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .back-link:hover { color: #c9a24a; }
  .back-arrow { font-size: 12px; }

  .header-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .header-title {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.35em;
    color: #c9a24a;
    text-transform: uppercase;
  }

  .header-omega {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    color: #5a4a32;
    letter-spacing: 0;
  }

  .header-file {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: #3a2e1e;
    text-transform: uppercase;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .lore-search {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 10px;
    border: 1px solid #2e2416;
    background: #17130d;
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    color: #7a6a50;
    text-transform: uppercase;
    transition: border-color 0.15s, color 0.15s;
  }
  .lore-search:hover { border-color: #c9a24a; color: #c9a24a; }
  .lore-search-icon { font-size: 13px; color: #c9a24a; }
  .lore-search-key {
    padding: 1px 5px;
    border: 1px solid #2e2416;
    color: #5a4a32;
    font-size: 8px;
  }

  
  .lore-body {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: opacity 0.25s ease;
  }

  .lore-header { transition: opacity 0.25s ease; }

  :global(body.search-transitioning) .lore-header,
  :global(body.search-transitioning) .lore-body {
    opacity: 0;
    pointer-events: none;
  }

  :global(.search-transition-overlay) {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  :global(.search-transition-ghost) {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 10px;
    border: 1px solid #c9a24a;
    background: rgba(23, 19, 13, 0.95);
    color: #c9a24a;
    opacity: 0;
    transform: scale(0.82);
    transition: transform 0.32s ease, opacity 0.2s ease;
  }

  :global(.search-transition-overlay.active) .search-transition-ghost {
    opacity: 1;
    transform: scale(1.38);
  }
</style>
